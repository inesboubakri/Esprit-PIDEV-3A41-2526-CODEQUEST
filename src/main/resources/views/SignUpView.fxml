<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/20" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SignUpController"
            stylesheets="@../styles.css">
    
    <center>
        <VBox alignment="CENTER" spacing="40" style="-fx-padding: 60;">
            <!-- Brand Section -->
            <VBox alignment="CENTER" spacing="16">
                <Label text="Code" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Quest" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                <Label text="Start Your Adventure!" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Create your account and begin mastering programming" style="-fx-font-size: 14; -fx-text-fill: #666;"/>
            </VBox>
            
            <!-- Form Container -->
            <VBox styleClass="card" style="-fx-min-width: 400; -fx-max-width: 450;" spacing="16">
                <!-- Full Name Field -->
                <VBox spacing="8">
                    <Label text="Full Name" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField promptText="Enter your full name" styleClass="text-input" fx:id="nameField"/>
                </VBox>
                
                <!-- Email Field -->
                <VBox spacing="8">
                    <Label text="Email Address" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField promptText="Enter your email" styleClass="text-input" fx:id="emailField"/>
                </VBox>
                
                <!-- Password Field -->
                <VBox spacing="8">
                    <Label text="Password" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <PasswordField promptText="Create a password" styleClass="text-input" fx:id="passwordField"/>
                    <Label text="At least 8 characters, include numbers and symbols" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                </VBox>
                
                <!-- Confirm Password Field -->
                <VBox spacing="8">
                    <Label text="Confirm Password" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <PasswordField promptText="Confirm your password" styleClass="text-input" fx:id="confirmPasswordField"/>
                </VBox>
                
                <!-- Terms Agreement -->
                <VBox spacing="12">
                    <CheckBox style="-fx-font-size: 12; -fx-text-fill: #666;">
                        <graphic>
                            <Label text="I agree to the Terms of Service and Privacy Policy" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                        </graphic>
                    </CheckBox>
                    <CheckBox style="-fx-font-size: 12; -fx-text-fill: #666;">
                        <graphic>
                            <Label text="Send me updates and announcements" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                        </graphic>
                    </CheckBox>
                </VBox>
                
                <!-- Sign Up Button -->
                <Button text="Create Account" styleClass="btn-primary" style="-fx-padding: 14 20 14 20;" minWidth="300" onAction="#handleSignUp"/>
                
                <!-- Divider -->
                <HBox spacing="12" alignment="CENTER">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="or" style="-fx-text-fill: #999;"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <!-- Social SignUp -->
                <Button text="🔵 Sign up with Google" style="-fx-padding: 12 20 12 20; -fx-background-color: #F5F5F5; -fx-text-fill: #333; -fx-font-size: 14; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;" minWidth="300"/>
                <Button text="🐙 Sign up with GitHub" style="-fx-padding: 12 20 12 20; -fx-background-color: #F5F5F5; -fx-text-fill: #333; -fx-font-size: 14; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;" minWidth="300"/>
                
                <!-- Sign In Link -->
                <HBox alignment="CENTER" spacing="8">
                    <Label text="Already have an account?" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                    <Hyperlink text="Sign In Here" style="-fx-font-size: 12; -fx-text-fill: #FF6B4A; -fx-font-weight: bold;" onAction="#handleSignInRedirect"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>

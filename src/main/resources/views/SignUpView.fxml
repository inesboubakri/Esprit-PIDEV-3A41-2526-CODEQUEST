<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/20" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SignUpController"
            stylesheets="@../styles.css">
    
    <center>
        <ScrollPane fitToWidth="true" style="-fx-padding: 0; -fx-border-color: transparent;">
            <VBox alignment="TOP_CENTER" spacing="40" style="-fx-padding: 60;">
                <!-- Brand Section -->
                <VBox alignment="CENTER" spacing="16">
                <Label text="Code" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Quest" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                <Label text="Start Your Adventure!" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Create your account and begin mastering programming" style="-fx-font-size: 14; -fx-text-fill: #666;"/>
            </VBox>
            
            <!-- Form Container -->
            <VBox styleClass="card" style="-fx-min-width: 400; -fx-max-width: 450;" spacing="16">
                <!-- Full Name Field -->
                <VBox spacing="8">
                    <Label text="Full Name" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField promptText="Enter your full name" styleClass="text-input" fx:id="nameField"/>
                    <Label text="Letters, spaces, and hyphens only (no numbers or special characters)" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                </VBox>
                
                <!-- Email Field -->
                <VBox spacing="8">
                    <Label text="Email Address" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField promptText="Enter your email" styleClass="text-input" fx:id="emailField"/>
                    <Label text="Valid email format: user@example.com" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                </VBox>
                
                <!-- Password Field -->
                <VBox spacing="8">
                    <Label text="Password" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <PasswordField promptText="Create a password" styleClass="text-input" fx:id="passwordField"/>
                    <Label text="At least 6 characters, letters (A-Z, a-z) and numbers (0-9) only" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                </VBox>
                
                <!-- Confirm Password Field -->
                <VBox spacing="8">
                    <Label text="Confirm Password" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <PasswordField promptText="Confirm your password" styleClass="text-input" fx:id="confirmPasswordField"/>
                </VBox>
                
                <!-- Error & Success Messages -->
                <Label fx:id="errorLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false" wrapText="true"/>
                <Label fx:id="successLabel" text="✓ Account created successfully! Redirecting to Sign In..." style="-fx-text-fill: #4CAF50; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false"/>
                
                <!-- Terms Agreement -->
                <VBox spacing="12">
                    <CheckBox fx:id="termsCheckBox" style="-fx-font-size: 12; -fx-text-fill: #666;">
                        <graphic>
                            <Label text="I agree to the Terms of Service and Privacy Policy" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                        </graphic>
                    </CheckBox>
                    <CheckBox fx:id="newsletterCheckBox" style="-fx-font-size: 12; -fx-text-fill: #666;">
                        <graphic>
                            <Label text="Send me updates and announcements" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                        </graphic>
                    </CheckBox>
                </VBox>
                
                <!-- Sign Up Button -->
                <Button text="Create Account" styleClass="btn-primary" style="-fx-padding: 14 20 14 20;" minWidth="300" onAction="#handleSignUp"/>
                
                <!-- Divider -->
                <HBox spacing="12" alignment="CENTER">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="or" style="-fx-text-fill: #999;"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>
                
                <!-- Social SignUp Buttons -->
                <Button fx:id="googleSignUpButton" text="🔵 Sign up with Google" 
                        style="-fx-padding: 12 20 12 20; -fx-background-color: #FFFFFF; -fx-text-fill: #333; -fx-font-size: 14; -fx-border-color: #DADCE0; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;" 
                        minWidth="300" onAction="#handleGoogleSignUp">
                    <tooltip>
                        <Tooltip text="Sign up with your Google account"/>
                    </tooltip>
                </Button>
                
                <Button fx:id="githubSignUpButton" text="🐙 Sign up with GitHub" 
                        style="-fx-padding: 12 20 12 20; -fx-background-color: #24292e; -fx-text-fill: #FFFFFF; -fx-font-size: 14; -fx-border-color: #1b1f23; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;" 
                        minWidth="300" onAction="#handleGithubSignUp">
                    <tooltip>
                        <Tooltip text="Sign up with your GitHub account"/>
                    </tooltip>
                </Button>
                
                <Button fx:id="discordSignUpButton" text="🎮 Sign up with Discord" 
                        style="-fx-padding: 12 20 12 20; -fx-background-color: #5865F2; -fx-text-fill: #FFFFFF; -fx-font-size: 14; -fx-border-color: #4752C4; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;" 
                        minWidth="300" onAction="#handleDiscordSignUp">
                    <tooltip>
                        <Tooltip text="Sign up with your Discord account"/>
                    </tooltip>
                </Button>
                
                <!-- Social Email Verification Status -->
                <Label fx:id="socialEmailStatus" style="-fx-text-fill: #4CAF50; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false" wrapText="true"/>
                
                <!-- Sign In Link -->
                <HBox alignment="CENTER" spacing="8">
                    <Label text="Already have an account?" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                    <Hyperlink text="Sign In Here" style="-fx-font-size: 12; -fx-text-fill: #FF6B4A; -fx-font-weight: bold;" onAction="#handleSignInRedirect"/>
                </HBox>
            </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

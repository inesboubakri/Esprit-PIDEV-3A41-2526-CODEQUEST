<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ForgotPasswordController"
            stylesheets="@../styles.css">
    
    <center>
        <ScrollPane fitToWidth="true" style="-fx-padding: 0; -fx-border-color: transparent;">
            <VBox alignment="TOP_CENTER" spacing="40" style="-fx-padding: 60;">
                
                <!-- Header Section (Always Visible) -->
                <VBox alignment="CENTER" spacing="16">
                    <Label text="🔐" style="-fx-font-size: 64; -fx-text-alignment: center;"/>
                    <Label text="Forgot Password?" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Label text="We'll help you recover your account" style="-fx-font-size: 14; -fx-text-fill: #666;"/>
                </VBox>
                
                <!-- Main Card Container -->
                <VBox styleClass="card" style="-fx-min-width: 400; -fx-max-width: 450;" spacing="20">
                    
                    <!-- STEP 1: Email Entry -->
                    <VBox fx:id="stepEmailBox" spacing="16" visible="true" managed="true">
                        <Label text="Enter your account email address" style="-fx-font-size: 14; -fx-text-fill: #333;"/>
                        <TextField fx:id="resetEmailField" promptText="your@email.com" styleClass="text-input"/>
                        <Label fx:id="emailStepError" text="❌ Error message" style="-fx-text-fill: #d32f2f; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false" wrapText="true"/>
                        <Button fx:id="sendCodeButton" text="📧 Send Recovery Code" styleClass="btn-primary" style="-fx-padding: 14 20 14 20;" minWidth="300" onAction="#handleSendCode"/>
                        <Hyperlink text="← Back to Sign In" style="-fx-font-size: 12; -fx-text-fill: #FF6B4A; -fx-padding: 8 0 0 0;" onAction="#handleBackToSignIn"/>
                    </VBox>
                    
                    <!-- STEP 2: Code Entry -->
                    <VBox fx:id="stepCodeBox" spacing="16" visible="false" managed="false">
                        <Label fx:id="codeStepInfo" text="📧 Code sent to email@example.com" style="-fx-font-size: 12; -fx-text-fill: #4CAF50; -fx-font-weight: bold;"/>
                        <Label text="Enter the 6-digit code we sent" style="-fx-font-size: 14; -fx-text-fill: #333;"/>
                        <VBox alignment="CENTER">
                            <TextField fx:id="codeField" 
                                     promptText="000000" 
                                     style="-fx-alignment: center; -fx-font-size: 24; -fx-font-family: 'Courier New'; -fx-letter-spacing: 8; -fx-max-width: 220;"
                                     maxWidth="220"/>
                        </VBox>
                        <Label fx:id="codeStepError" text="❌ Invalid code" style="-fx-text-fill: #d32f2f; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false" wrapText="true"/>
                        <Button fx:id="codeVerifyButton" text="✅ Verify Code" styleClass="btn-primary" style="-fx-padding: 14 20 14 20;" minWidth="300" onAction="#handleVerifyCode"/>
                        <HBox alignment="CENTER">
                            <Hyperlink text="Resend code" style="-fx-font-size: 12; -fx-text-fill: #FF6B4A;" onAction="#handleResendCode"/>
                        </HBox>
                    </VBox>
                    
                    <!-- STEP 3: Password Reset -->
                    <VBox fx:id="stepNewPasswordBox" spacing="16" visible="false" managed="false">
                        <Label text="Create a new password" style="-fx-font-size: 14; -fx-text-fill: #333;"/>
                        <VBox spacing="8">
                            <Label text="New Password" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                            <PasswordField fx:id="newPasswordField" promptText="Min 6 chars, letters + numbers only" styleClass="text-input"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Confirm Password" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                            <PasswordField fx:id="confirmNewPasswordField" promptText="Confirm your password" styleClass="text-input"/>
                        </VBox>
                        <Label fx:id="passwordStepError" text="❌ Passwords do not match" style="-fx-text-fill: #d32f2f; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false" wrapText="true"/>
                        <Button fx:id="resetPasswordButton" text="🔒 Reset Password" styleClass="btn-primary" style="-fx-padding: 14 20 14 20;" minWidth="300" onAction="#handleResetPassword"/>
                    </VBox>
                    
                </VBox>
                
            </VBox>
        </ScrollPane>
    </center>
    
</BorderPane>

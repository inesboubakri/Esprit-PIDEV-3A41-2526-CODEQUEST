<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/20" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EditProfileController"
            stylesheets="@../styles.css"
            style="-fx-padding: 30;">
    
    <center>
        <ScrollPane fitToWidth="true" style="-fx-padding: 0;">
            <VBox spacing="20" style="-fx-max-width: 600; -fx-alignment: TOP_CENTER; -fx-padding: 20;">
                
                <!-- Title -->
                <Label text="Edit Your Profile" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            
            <!-- Form Container -->
            <VBox styleClass="card" spacing="16" style="-fx-padding: 30; -fx-border-radius: 12; -fx-background-radius: 12;">
                
                <!-- Full Name -->
                <VBox spacing="6">
                    <Label text="Full Name" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="nameField" promptText="Enter your full name" styleClass="text-input"/>
                </VBox>
                
                <!-- Email (Read-only) -->
                <VBox spacing="6">
                    <Label text="Email Address" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="emailField" promptText="Email" styleClass="text-input" disable="true"/>
                    <Label text="Email cannot be changed" style="-fx-font-size: 10; -fx-text-fill: #999;"/>
                </VBox>
                
                <!-- Role -->
                <VBox spacing="6">
                    <Label text="Role" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="roleField" promptText="e.g., Developer, Designer, Manager" styleClass="text-input"/>
                </VBox>
                
                <!-- Niveau Info (Level/Skill Level) -->
                <VBox spacing="6">
                    <Label text="Skill Level" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <ComboBox fx:id="niveauCombo" styleClass="text-input" style="-fx-pref-width: 300; -fx-min-height: 40;"/>
                </VBox>
                
                <!-- Age -->
                <VBox spacing="6">
                    <Label text="Age" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="ageField" promptText="Enter your age (numbers only)" styleClass="text-input"/>
                </VBox>
                
                <!-- Education -->
                <VBox spacing="6">
                    <Label text="Education" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="educationField" promptText="e.g., Bachelor's in Computer Science" styleClass="text-input"/>
                </VBox>
                
                <!-- Formation (Training/Certifications) -->
                <VBox spacing="6">
                    <Label text="Certifications / Training" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="formationField" promptText="e.g., AWS Certified, Oracle Java Certified" styleClass="text-input"/>
                </VBox>
                
                <!-- Experience -->
                <VBox spacing="6">
                    <Label text="Experience" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextField fx:id="experienceField" promptText="e.g., 5 years in Full Stack Development" styleClass="text-input"/>
                </VBox>
                
                <!-- Bio -->
                <VBox spacing="6">
                    <Label text="Bio" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <TextArea fx:id="bioArea" 
                              promptText="Tell other programmers about yourself..." 
                              styleClass="text-input"
                              style="-fx-control-inner-background: white; -fx-text-fill: #333; -fx-font-family: System; -fx-font-size: 12; -fx-wrap-text: true;" 
                              wrapText="true" 
                              prefRowCount="4" 
                              prefColumnCount="30"/>
                    
                    <!-- Generate Bio Button Row -->
                    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 8 0 0 0;">
                        <Button fx:id="generateBioButton"
                                text="✨ Generate with AI"
                                onAction="#handleGenerateBio"
                                style="-fx-background-color: linear-gradient(to right, #FF6B4A, #ff8c6a); -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 8 16 8 16; -fx-background-radius: 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,107,74,0.3), 6, 0, 0, 2);"/>
                        <Label fx:id="bioGenerateStatus" 
                               text="" 
                               visible="false" 
                               managed="false"
                               style="-fx-font-size: 11; -fx-font-style: italic; -fx-text-fill: #999;"/>
                    </HBox>
                </VBox>
                
                <!-- Error Message -->
                <Label fx:id="errorLabel" text="" style="-fx-text-fill: #d32f2f; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false"/>
                
                <!-- Success Message -->
                <Label fx:id="successLabel" text="" style="-fx-text-fill: #4CAF50; -fx-font-size: 12; -fx-font-weight: bold;" visible="false" managed="false"/>
                
                <!-- Buttons -->
                <HBox spacing="12" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                    <Button text="Save Changes" style="-fx-padding: 12 30 12 30; -fx-font-size: 14; -fx-background-color: #FF6B4A; -fx-text-fill: white; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-weight: bold;" 
                            minWidth="120" onAction="#handleSaveProfile"/>
                    <Button text="Cancel" style="-fx-padding: 12 30 12 30; -fx-font-size: 14; -fx-background-color: #E0E0E0; -fx-text-fill: #333; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-weight: bold;" 
                            minWidth="120" onAction="#handleCancel"/>
                </HBox>
            </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

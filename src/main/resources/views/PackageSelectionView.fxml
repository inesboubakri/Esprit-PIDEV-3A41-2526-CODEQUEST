<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PackageSelectionController"
            stylesheets="@../styles.css"
            style="-fx-background-color: #F5F5F5;">

    <!-- HEADER BAR -->
    <top>
        <VBox style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, #DDDDDD, 6, 0, 0, 2);">
            <padding>
                <Insets top="16" right="32" bottom="16" left="32"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="🚀 CodeQuest" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userWelcomeLabel" text="Welcome!" style="-fx-font-size: 14; -fx-text-fill: #666666;"/>
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: #F5F5F5;">
            <VBox alignment="TOP_CENTER" spacing="32">
                <padding>
                    <Insets top="48" right="40" bottom="48" left="40"/>
                </padding>

                <!-- TITLE SECTION -->
                <VBox alignment="CENTER" spacing="8">
                    <Label text="Choose Your Plan" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <Label text="Select the plan that fits your journey" style="-fx-font-size: 14; -fx-text-fill: #666666;"/>
                </VBox>

                <!-- CARDS CONTAINER -->
                <HBox alignment="CENTER" spacing="32">

                    <!-- FREE CARD -->
                    <VBox fx:id="freeCard" spacing="0" minWidth="320" maxWidth="380" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, #DDDDDD, 8, 0, 0, 2);">
                        <VBox spacing="20">
                            <padding>
                                <Insets top="32" right="32" bottom="32" left="32"/>
                            </padding>

                            <!-- FREE BADGE -->
                            <HBox alignment="CENTER_LEFT">
                                <Label text="FREE" style="-fx-background-color: #F5F5F5; -fx-text-fill: #616161; -fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 4 10 4 10; -fx-background-radius: 12;"/>
                            </HBox>

                            <!-- PRICE -->
                            <VBox spacing="4">
                                <HBox alignment="BASELINE_LEFT" spacing="4">
                                    <Label text="\$0" style="-fx-font-size: 38; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                                    <Label text="/month" style="-fx-font-size: 14; -fx-text-fill: #666666; -fx-padding: 0 0 8 0;"/>
                                </HBox>
                            </VBox>

                            <!-- DIVIDER -->
                            <Region prefHeight="1" maxWidth="1000" style="-fx-background-color: #EEEEEE;"/>

                            <!-- FEATURES -->
                            <VBox spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="Access to basic courses" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="5 problems per day" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="Community forum access" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #4CAF50; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="Basic profile" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                            </VBox>

                            <!-- BUTTON -->
                            <Button text="Get Started Free" onAction="#handleFreePackage" maxWidth="1000" style="-fx-background-color: #FFFFFF; -fx-text-fill: #FF6B4A; -fx-border-color: #FF6B4A; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 12 20 12 20; -fx-cursor: hand;"/>

                        </VBox>
                    </VBox>

                    <!-- PREMIUM CARD -->
                    <VBox fx:id="premiumCard" spacing="0" minWidth="320" maxWidth="380" style="-fx-background-color: #FFFFFF; -fx-border-color: #FF6B4A; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, #DDDDDD, 12, 0, 0, 3);">

                        <!-- TOP ACCENT BAR -->
                        <Label text="" prefHeight="5" maxWidth="1000" style="-fx-background-color: #FF6B4A;"/>

                        <VBox spacing="20">
                            <padding>
                                <Insets top="28" right="32" bottom="32" left="32"/>
                            </padding>

                            <!-- PRO BADGE -->
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="PRO" style="-fx-background-color: #FFF8E1; -fx-text-fill: #FFA000; -fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 4 10 4 10; -fx-background-radius: 12; -fx-border-color: #FFCA28; -fx-border-radius: 12;"/>
                                <Label text="⭐ MOST POPULAR" style="-fx-font-size: 11; -fx-text-fill: #FFA000; -fx-font-weight: bold;"/>
                            </HBox>

                            <!-- PRICE -->
                            <VBox spacing="4">
                                <HBox alignment="BASELINE_LEFT" spacing="4">
                                    <Label text="\$9.99" style="-fx-font-size: 38; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                                    <Label text="/month" style="-fx-font-size: 14; -fx-text-fill: #666666; -fx-padding: 0 0 8 0;"/>
                                </HBox>
                            </VBox>

                            <!-- DIVIDER -->
                            <Region prefHeight="1" maxWidth="1000" style="-fx-background-color: #EEEEEE;"/>

                            <!-- FEATURES -->
                            <VBox spacing="12">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #FF6B4A; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="All Free features included" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #FF6B4A; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="Unlimited problems" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #FF6B4A; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="AI Assistant (Mistral)" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #FF6B4A; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="Priority support" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #FF6B4A; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="Exclusive projects" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="✓" style="-fx-text-fill: #FF6B4A; -fx-font-weight: bold; -fx-font-size: 14;"/>
                                    <Label text="Premium badge on profile" style="-fx-text-fill: #333333; -fx-font-size: 13;"/>
                                </HBox>
                            </VBox>

                            <!-- BUTTON -->
                            <Button text="Get Premium Now 🚀" onAction="#handlePremiumPackage" maxWidth="1000" style="-fx-background-color: #FF6B4A; -fx-text-fill: #FFFFFF; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 12 20 12 20; -fx-cursor: hand;"/>

                        </VBox>
                    </VBox>

                </HBox>

                <!-- STATUS LABEL -->
                <Label fx:id="statusLabel" text="" visible="false" managed="false" style="-fx-font-size: 13; -fx-text-fill: #D32F2F;"/>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.DashboardController" stylesheets="@../dashboard.css">
    
    <!-- Left Sidebar Navigation -->
    <left>
        <VBox styleClass="sidebar" spacing="0" style="-fx-min-width: 250; -fx-max-width: 250; -fx-pref-width: 250; -fx-background-color: #FFFFFF; -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0; -fx-spacing: 0;">
            <!-- Logo -->
            <HBox spacing="4" alignment="CENTER_LEFT" style="-fx-padding: 0 0 30 0; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                <Label text="Code" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Quest" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
            </HBox>
            
            <!-- Navigation Menu -->
            <VBox fx:id="sidebarContent" spacing="8" style="-fx-fill-height: true;">
                <Hyperlink text="📊 Dashboard" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-background-color: #FF6B4A; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-font-size: 14;" onAction="#handleNavDashboard"/>
                <Hyperlink text="👥 Users" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavUsers"/>
                <Hyperlink text="📚 Courses" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavCourses"/>
                <Hyperlink text="🤝 Forum" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavForum"/>
                <Hyperlink text="✏️ Problems" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavProblems"/>
                <Hyperlink text="🎯 Projects" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavProjects"/>
                <Hyperlink text="🏆 Events" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavEvents"/>
            </VBox>
            
            <!-- Sidebar Footer -->
            <Region VBox.vgrow="ALWAYS"/>
            <VBox style="-fx-background-color: rgba(255, 107, 74, 0.1); -fx-padding: 20; -fx-background-radius: 10; -fx-border-radius: 10;" alignment="CENTER" spacing="15">
                <Label text="Level up your skills! 🚀" style="-fx-font-size: 13; -fx-text-fill: #333; -fx-wrap-text: true; -fx-text-alignment: center; -fx-font-weight: 600;"/>
                <Label text="👨‍🚀" style="-fx-font-size: 48;"/>
            </VBox>
        </VBox>
    </left>
    
    <!-- Main Content Area -->
    <center>
        <VBox spacing="0">
            <!-- Top Header Bar -->
            <HBox style="-fx-background-color: white; -fx-padding: 20 40 20 40; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;" spacing="20" alignment="CENTER_LEFT">
                <Label text="Admin Dashboard" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Search Bar -->
                <HBox spacing="0" style="-fx-background-color: #F5F5F5; -fx-padding: 10 16 10 16; -fx-background-radius: 8;">
                    <TextField promptText="Search..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-min-width: 200; -fx-font-size: 14;" fx:id="searchField"/>
                    <Button text="🔍" style="-fx-background-color: transparent; -fx-text-fill: #999; -fx-cursor: hand; -fx-font-size: 14;"/>
                </HBox>
                
                <!-- Theme Toggle -->
                <Button text="🌙" style="-fx-background-color: transparent; -fx-font-size: 18; -fx-padding: 8; -fx-cursor: hand;" onAction="#handleThemeToggle"/>
                
                <!-- Admin Profile -->
                <HBox spacing="12" alignment="CENTER">
                    <Label text="👤" style="-fx-font-size: 28;"/>
                    <Label text="Admin" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #333;"/>
                </HBox>
            </HBox>
            
            <!-- Scrollable Content -->
            <ScrollPane fitToWidth="true" style="-fx-border-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 40;">
                    <!-- Statistics Cards (6 columns) -->
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="16.66"/>
                            <ColumnConstraints percentWidth="16.66"/>
                            <ColumnConstraints percentWidth="16.66"/>
                            <ColumnConstraints percentWidth="16.66"/>
                            <ColumnConstraints percentWidth="16.66"/>
                            <ColumnConstraints percentWidth="16.66"/>
                        </columnConstraints>
                        
                        <!-- Total Users Card -->
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Total Users" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="1,234" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+12% from last month" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                            <ProgressBar style="-fx-min-height: 4;" progress="0.75"/>
                        </VBox>
                        
                        <!-- Active Courses Card -->
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Active Courses" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="56" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+5% this week" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                            <ProgressBar style="-fx-min-height: 4;" progress="0.60"/>
                        </VBox>
                        
                        <!-- Forum Posts Card -->
                        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Forum Posts" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="789" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="-2% yesterday" style="-fx-font-size: 11; -fx-text-fill: #d32f2f; -fx-background-color: #f8d7da; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                            <ProgressBar style="-fx-min-height: 4;" progress="0.85"/>
                        </VBox>
                        
                        <!-- Problems Solved Card -->
                        <VBox GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Problems Solved" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="12,345" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+18% this month" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                            <ProgressBar style="-fx-min-height: 4;" progress="0.90"/>
                        </VBox>
                        
                        <!-- Projects Submitted Card -->
                        <VBox GridPane.columnIndex="4" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Projects Submitted" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="234" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+8% last week" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                            <ProgressBar style="-fx-min-height: 4;" progress="0.70"/>
                        </VBox>
                        
                        <!-- Events Hosted Card -->
                        <VBox GridPane.columnIndex="5" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Events Hosted" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="12" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+25% this quarter" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                            <ProgressBar style="-fx-min-height: 4;" progress="0.50"/>
                        </VBox>
                    </GridPane>
                    
                    <!-- Dashboard Grid (Top Users + Recent Activity) -->
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        
                        <!-- Top Active Users Section -->
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="15">
                            <Label text="Top Active Users" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                            
                            <!-- User Item 1 -->
                            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 12 0 12 0; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                                <Label text="JD" style="-fx-background-color: #FF6B4A; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-min-width: 40; -fx-min-height: 40; -fx-alignment: center; -fx-background-radius: 20;"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="John Doe" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #333;"/>
                                    <Label text="Level 15 • 2,450 XP" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                                </VBox>
                                <Label text="⭐ 4.8" style="-fx-font-size: 14; -fx-text-fill: #FF6B4A;"/>
                            </HBox>
                            
                            <!-- User Item 2 -->
                            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 12 0 12 0; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                                <Label text="SM" style="-fx-background-color: #FF6B4A; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-min-width: 40; -fx-min-height: 40; -fx-alignment: center; -fx-background-radius: 20;"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Sarah Miller" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #333;"/>
                                    <Label text="Level 12 • 1,890 XP" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                                </VBox>
                                <Label text="⭐ 4.7" style="-fx-font-size: 14; -fx-text-fill: #FF6B4A;"/>
                            </HBox>
                            
                            <!-- User Item 3 -->
                            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 0;">
                                <Label text="AK" style="-fx-background-color: #FF6B4A; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-min-width: 40; -fx-min-height: 40; -fx-alignment: center; -fx-background-radius: 20;"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Alex Kim" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #333;"/>
                                    <Label text="Level 10 • 1,650 XP" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                                </VBox>
                                <Label text="⭐ 4.6" style="-fx-font-size: 14; -fx-text-fill: #FF6B4A;"/>
                            </HBox>
                        </VBox>
                        
                        <!-- Recent Activity Section -->
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="15">
                            <Label text="Recent Activity" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                            
                            <!-- Activity Item 1 -->
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-padding: 12 0 12 0; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                                <Label text="👤" style="-fx-font-size: 18;"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="John Doe registered and completed &quot;Python Basics&quot;" style="-fx-font-size: 13; -fx-text-fill: #333; -fx-wrap-text: true;"/>
                                    <Label text="2 minutes ago" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                                </VBox>
                            </HBox>
                            
                            <!-- Activity Item 2 -->
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-padding: 12 0 12 0; -fx-border-color: #f0f0f0; -fx-border-width: 0 0 1 0;">
                                <Label text="📚" style="-fx-font-size: 18;"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Course &quot;JavaScript Advanced&quot; completed by 5 users" style="-fx-font-size: 13; -fx-text-fill: #333; -fx-wrap-text: true;"/>
                                    <Label text="15 minutes ago" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                                </VBox>
                            </HBox>
                            
                            <!-- Activity Item 3 -->
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-padding: 12 0 0 0;">
                                <Label text="💬" style="-fx-font-size: 18;"/>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="New forum post: &quot;Help with React hooks&quot; in General Discussion" style="-fx-font-size: 13; -fx-text-fill: #333; -fx-wrap-text: true;"/>
                                    <Label text="1 hour ago" style="-fx-font-size: 11; -fx-text-fill: #999;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </GridPane>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>

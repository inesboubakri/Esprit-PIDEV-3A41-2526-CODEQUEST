<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/20" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminDashboardController"
            stylesheets="@../styles.css">
    
    <!-- Top Navigation Bar -->
    <top>
        <HBox spacing="15" style="-fx-padding: 15 20; -fx-background-color: linear-gradient(to bottom, rgba(255, 107, 74, 0.9), rgba(0, 0, 0, 0.4)); -fx-alignment: CENTER_LEFT;">
            <Label text="Admin Dashboard" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="adminNameLabel" style="-fx-text-fill: white; -fx-font-size: 12;"/>
            <Button text="Logout" onAction="#handleLogOut" 
                    style="-fx-text-fill: white; -fx-background-color: transparent; -fx-font-size: 12; -fx-cursor: hand;"/>
        </HBox>
    </top>
    
    <!-- Left Sidebar -->
    <left>
        <VBox style="-fx-background-color: #252525; -fx-padding: 20; -fx-min-width: 220;" spacing="15">
            <Label text="Dashboard" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: white;"/>
            
            <Button text="Users" onAction="#handleViewUsers" 
                    style="-fx-background-color: #FF6B4A; -fx-text-fill: white; -fx-padding: 10; -fx-font-size: 12; -fx-cursor: hand;" maxWidth="Infinity"/>
            
            <Button text="Statistics" onAction="#handleViewStats" 
                    style="-fx-background-color: rgba(255, 107, 74, 0.6); -fx-text-fill: white; -fx-padding: 10; -fx-font-size: 12; -fx-cursor: hand;" maxWidth="Infinity"/>
            
            <Separator style="-fx-border-color: #444;"/>
            
            <Label text="Quick Actions" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: white;"/>
            
            <Button text="Add New User" onAction="#handleAddUser" 
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-padding: 10; -fx-font-size: 12; -fx-cursor: hand;" maxWidth="Infinity"/>
        </VBox>
    </left>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 30; -fx-background-color: #1a1a1a;">
            
            <!-- Search and Filter Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search users by name or email..." style="-fx-padding: 10; -fx-font-size: 12; -fx-background-color: rgba(255, 255, 255, 0.08); -fx-text-fill: white; -fx-border-color: rgba(255, 255, 255, 0.15); -fx-border-width: 1; -fx-border-radius: 6;" HBox.hgrow="ALWAYS"/>
                <Button text="Search" onAction="#handleSearch" styleClass="btn-primary"
                        style="-fx-padding: 10 20; -fx-font-size: 12; -fx-font-weight: 600; -fx-cursor: hand;"/>
                <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"
                        style="-fx-padding: 10 20; -fx-font-size: 12; -fx-font-weight: 600; -fx-cursor: hand;"/>
            </HBox>
            
            <!-- Users Table -->
            <VBox style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-padding: 20; -fx-border-radius: 12; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-width: 1;" VBox.vgrow="ALWAYS">
                <Label text="Users Management" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                
                <TableView fx:id="usersTable" style="-fx-font-size: 11; -fx-text-fill: white; -fx-control-inner-background: rgba(255, 255, 255, 0.03);" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="ID" prefWidth="50" fx:id="idColumn"/>
                        <TableColumn text="Name" prefWidth="150" fx:id="nameColumn"/>
                        <TableColumn text="Email" prefWidth="180" fx:id="emailColumn"/>
                        <TableColumn text="Role" prefWidth="100" fx:id="roleColumn"/>
                        <TableColumn text="Level" prefWidth="80" fx:id="levelColumn"/>
                        <TableColumn text="Admin" prefWidth="60" fx:id="adminColumn"/>
                        <TableColumn text="Banned" prefWidth="60" fx:id="bannedColumn"/>
                        <TableColumn text="Actions" prefWidth="200" fx:id="actionsColumn"/>
                    </columns>
                </TableView>
            </VBox>
            
            <!-- Status Bar -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 12; -fx-background-color: rgba(76, 175, 80, 0.15); -fx-border-radius: 6; -fx-border-color: rgba(76, 175, 80, 0.3); -fx-border-width: 1;">
                <Label fx:id="statusLabel" text="Loading users..." style="-fx-font-size: 12; -fx-text-fill: rgba(255, 255, 255, 0.8);"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>

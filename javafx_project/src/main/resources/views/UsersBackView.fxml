<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.UsersBackController" stylesheets="@../dashboard.css">
    
    <left>
        <VBox styleClass="sidebar" spacing="0" style="-fx-min-width: 250; -fx-max-width: 250; -fx-pref-width: 250; -fx-background-color: #FFFFFF; -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0; -fx-spacing: 0;">
            <!-- Logo -->
            <HBox spacing="4" alignment="CENTER_LEFT" style="-fx-padding: 0 0 30 0; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                <Label text="Code" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Quest" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
            </HBox>
            
            <!-- Navigation Menu -->
            <VBox fx:id="sidebarContent" spacing="8" style="-fx-fill-height: true;">
                <Hyperlink text="📊 Dashboard" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavDashboard"/>
                <Hyperlink text="👥 Users" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-background-color: #FF6B4A; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-font-size: 14;" onAction="#handleNavUsers"/>
                <Hyperlink text="📚 Courses" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavCourses"/>
                <Hyperlink text="🤝 Forum" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavForum"/>
                <Hyperlink text="✏️ Problems" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavProblems"/>
                <Hyperlink text="🎯 Projects" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavProjects"/>
                <Hyperlink text="🏆 Events" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavEvents"/>
            </VBox>
            
            <!-- Sidebar Footer -->
            <Region VBox.hgrow="ALWAYS"/>
            <VBox style="-fx-background-color: rgba(255, 107, 74, 0.1); -fx-padding: 20; -fx-background-radius: 10; -fx-border-radius: 10;" alignment="CENTER" spacing="15">
                <Label text="Level up your skills! 🚀" style="-fx-font-size: 13; -fx-text-fill: #333; -fx-wrap-text: true; -fx-text-alignment: center; -fx-font-weight: 600;"/>
                <Label text="👨‍🚀" style="-fx-font-size: 48;"/>
            </VBox>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="0" style="-fx-background-color: #F5F5F5;">
            <!-- Header -->
            <HBox style="-fx-background-color: white; -fx-padding: 20 40 20 40; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;" spacing="20" alignment="CENTER_LEFT">
                <Label text="Users Management" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="0" style="-fx-background-color: #F5F5F5; -fx-padding: 10 16 10 16; -fx-background-radius: 8;">
                    <TextField fx:id="searchField" promptText="Search users..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-min-width: 200; -fx-font-size: 14;"/>
                    <Button text="🔍" style="-fx-background-color: transparent; -fx-text-fill: #999; -fx-cursor: hand; -fx-font-size: 14;"/>
                </HBox>
                <Button text="🌙" style="-fx-background-color: transparent; -fx-font-size: 18; -fx-padding: 8; -fx-cursor: hand;" onAction="#handleThemeToggle"/>
                <HBox spacing="12" alignment="CENTER">
                    <Label text="👤" style="-fx-font-size: 28;"/>
                    <Label text="Admin" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #333;"/>
                </HBox>
            </HBox>
            
            <!-- Scrollable Content -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 40;">
                    <!-- User Stats -->
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>
                        
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Total Users" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="1,234" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+12% this month" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                        
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Active Users" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="987" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+8% this week" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                        
                        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Users Level 8+" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="156" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+15% this month" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                        
                        <VBox GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="New Registrations" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label text="89" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+23% this week" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                    </GridPane>
                    
                    <!-- Filters and Actions Section -->
                    <HBox spacing="20" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" alignment="CENTER_LEFT">
                        <HBox spacing="12">
                            <Button fx:id="filterAllBtn" text="All Users" style="-fx-padding: 8 16; -fx-text-fill: white; -fx-background-color: #FF6B4A; -fx-font-weight: 500; -fx-cursor: hand;" onAction="#handleFilterAll"/>
                            <Button fx:id="filterActiveBtn" text="Active" style="-fx-padding: 8 16; -fx-background-color: #f0f0f0; -fx-text-fill: #666; -fx-font-weight: 500; -fx-cursor: hand;" onAction="#handleFilterActive"/>
                            <Button fx:id="filterInactiveBtn" text="Inactive" style="-fx-padding: 8 16; -fx-background-color: #f0f0f0; -fx-text-fill: #666; -fx-font-weight: 500; -fx-cursor: hand;" onAction="#handleFilterInactive"/>
                            <Button fx:id="filterAdminBtn" text="Admins" style="-fx-padding: 8 16; -fx-background-color: #f0f0f0; -fx-text-fill: #666; -fx-font-weight: 500; -fx-cursor: hand;" onAction="#handleFilterAdmin"/>
                            <Button fx:id="filterTeacherBtn" text="Teachers" style="-fx-padding: 8 16; -fx-background-color: #f0f0f0; -fx-text-fill: #666; -fx-font-weight: 500; -fx-cursor: hand;" onAction="#handleFilterTeacher"/>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="📊 View Stats" style="-fx-padding: 10 20; -fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: 500; -fx-cursor: hand;"/>
                        <Button fx:id="addUserBtn" text="+ Add New User" style="-fx-padding: 10 20; -fx-background-color: #FF6B4A; -fx-text-fill: white; -fx-font-weight: 500; -fx-cursor: hand;" onAction="#handleAddUser"/>
                    </HBox>
                    
                    <!-- Users Table -->
                    <TableView fx:id="usersTable" style="-fx-font-size: 13; -fx-background-color: white;" pickOnBounds="false">
                        <columns>
                            <TableColumn text="User" prefWidth="180"/>
                            <TableColumn text="Email" prefWidth="180"/>
                            <TableColumn text="Level" prefWidth="80"/>
                            <TableColumn text="XP" prefWidth="120"/>
                            <TableColumn text="Status" prefWidth="100"/>
                            <TableColumn text="Join Date" prefWidth="120"/>
                            <TableColumn text="Last Active" prefWidth="120"/>
                            <TableColumn text="Actions" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
    
    <left>
        <VBox styleClass="sidebar" spacing="0" style="-fx-min-width: 280; -fx-background-color: #FFFFFF; -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
            <!-- Logo -->
            <HBox spacing="4" alignment="CENTER_LEFT" style="-fx-padding: 0 0 30 0; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                <Label text="Code" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Quest" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
            </HBox>
            
            <!-- Navigation Menu -->
            <VBox fx:id="sidebarContent" spacing="8" style="-fx-fill-height: true;">
                <Hyperlink text="📊 Dashboard" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavDashboard"/>
                <Hyperlink text="👥 Users" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-background-color: #FF6B4A; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-font-size: 14;" onAction="#handleNavUsers"/>
                <Hyperlink text="📚 Courses" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavCourses"/>
                <Hyperlink text="🤝 Forum" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavForum"/>
                <Hyperlink text="✏️ Problems" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavProblems"/>
                <Hyperlink text="🎯 Projects" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavProjects"/>
                <Hyperlink text="🏆 Events" style="-fx-text-fill: #333; -fx-padding: 12 15 12 15; -fx-font-size: 14; -fx-font-weight: 500;" onAction="#handleNavEvents"/>
            </VBox>
            
            <!-- Sidebar Footer -->
            <Region VBox.vgrow="ALWAYS"/>
            <VBox style="-fx-background-color: rgba(255, 107, 74, 0.1); -fx-padding: 20; -fx-background-radius: 10; -fx-border-radius: 10;" alignment="CENTER" spacing="15">
                <Label text="Level up your skills! 🚀" style="-fx-font-size: 13; -fx-text-fill: #333; -fx-wrap-text: true; -fx-text-alignment: center; -fx-font-weight: 600;"/>
                <Label text="👨‍🚀" style="-fx-font-size: 48;"/>
            </VBox>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="0" style="-fx-background-color: #F5F5F5;">
            <!-- Header -->
            <HBox style="-fx-background-color: white; -fx-padding: 20 40 20 40; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;" spacing="20" alignment="CENTER_LEFT">
                <Label text="Users Management" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="0" style="-fx-background-color: #F5F5F5; -fx-padding: 10 16 10 16; -fx-background-radius: 8;">
                    <TextField fx:id="searchField" promptText="Search users..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-min-width: 250; -fx-font-size: 14;"/>
                    <Button text="🔍" style="-fx-background-color: transparent; -fx-text-fill: #999; -fx-cursor: hand; -fx-font-size: 14;"/>
                </HBox>
                <Button text="🌙" style="-fx-background-color: transparent; -fx-font-size: 18; -fx-padding: 8; -fx-cursor: hand;" onAction="#handleThemeToggle"/>
                <HBox spacing="12" alignment="CENTER">
                    <Label text="👤" style="-fx-font-size: 28;"/>
                    <Label text="Admin" style="-fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #333;"/>
                </HBox>
            </HBox>
            
            <!-- Scrollable Content -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 40;">
                    <!-- User Stats Cards -->
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>
                        
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Total Users" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+12% this month" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                        
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Active Users" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label fx:id="activeUsersLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+8% this week" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                        
                        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="Premium Users" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label fx:id="premiumUsersLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+5% this month" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                        
                        <VBox GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" spacing="10">
                            <Label text="New This Month" style="-fx-font-size: 12; -fx-font-weight: 600; -fx-text-fill: #666; -fx-text-transform: uppercase;"/>
                            <Label fx:id="newThisMonthLabel" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #FF6B4A;"/>
                            <Label text="+23% this week" style="-fx-font-size: 11; -fx-text-fill: #4CAF50; -fx-background-color: #d4edda; -fx-padding: 4 8; -fx-background-radius: 4; -fx-text-alignment: center;"/>
                        </VBox>
                    </GridPane>
                    
                    <!-- Filters and Actions Section -->
                    <HBox spacing="20" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);" alignment="CENTER_LEFT">
                        <HBox spacing="10">
                            <Button fx:id="filterAllBtn" text="All Users" style="-fx-padding: 8 16; -fx-text-fill: white; -fx-background-color: #FF6B4A; -fx-font-weight: 500;" onAction="#handleFilterAll"/>
                            <Button fx:id="filterAdminBtn" text="Admins" style="-fx-padding: 8 16; -fx-background-color: #f0f0f0; -fx-font-weight: 500;" onAction="#handleFilterAdmin"/>
                            <Button fx:id="filterTeacherBtn" text="Teachers" style="-fx-padding: 8 16; -fx-background-color: #f0f0f0; -fx-font-weight: 500;" onAction="#handleFilterTeacher"/>
                            <Button fx:id="filterStudentBtn" text="Students" style="-fx-padding: 8 16; -fx-background-color: #f0f0f0; -fx-font-weight: 500;" onAction="#handleFilterStudent"/>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="📊 View Stats" style="-fx-padding: 10 20; -fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: 500;"/>
                        <Button fx:id="addUserBtn" text="+ Add New User" style="-fx-padding: 10 20; -fx-background-color: #FF6B4A; -fx-text-fill: white; -fx-font-weight: 500;" onAction="#handleAddUser"/>
                    </HBox>
                    
                    <!-- Users Table -->
                    <TableView fx:id="usersTable" style="-fx-font-size: 13; -fx-background-color: white;" pickOnBounds="false">
                        <columns>
                            <TableColumn text="User ID" prefWidth="110"/>
                            <TableColumn text="Name" prefWidth="180"/>
                            <TableColumn text="Email" prefWidth="220"/>
                            <TableColumn text="Level" prefWidth="100"/>
                            <TableColumn text="Status" prefWidth="110"/>
                            <TableColumn text="Joined Date" prefWidth="130"/>
                            <TableColumn text="Actions" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
